rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /wines/{document} {
      // Wines can be read by anyone, but writes require authentication
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{document=**} {
      // All other collections require authentication to read and write
      allow read, write: if request.auth != null;
    }
  }
}
