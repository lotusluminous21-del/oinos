generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/pavlicevits_prototype/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  order       Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String
  price          Float
  image          String?
  categoryId     String
  category       Category @relation(fields: [categoryId], references: [id])
  brand          String?
  sku            String?
  inStock        Boolean  @default(true)
  expertTip      String?
  compatibleWith String[]
  tags           String[]
  createdAt      DateTime @default(now())
  stepProducts   StepProduct[]
  cartItems      CartItem[]
}

model ProjectTemplate {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  description String
  keywords    String[]
  difficulty  String        @default("medium")
  timeEstimate String?
  steps       ProjectStep[]
  createdAt   DateTime      @default(now())
}

model ProjectStep {
  id          String          @id @default(cuid())
  templateId  String
  template    ProjectTemplate @relation(fields: [templateId], references: [id])
  stepNumber  Int
  title       String
  description String
  proTips     String[]
  products    StepProduct[]
}

model StepProduct {
  id        String      @id @default(cuid())
  stepId    String
  step      ProjectStep @relation(fields: [stepId], references: [id])
  productId String
  product   Product     @relation(fields: [productId], references: [id])
  isRequired Boolean    @default(true)
  note      String?
}

model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  @@unique([sessionId, productId])
}

model ActiveProject {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  templateId String
  title      String
  createdAt  DateTime @default(now())
}
